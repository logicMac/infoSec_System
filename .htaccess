# Enable RewriteEngine
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /
</IfModule>

# ----------------------------------------------------------------------
# Rewrite rules for backend API (Express.js)
# ----------------------------------------------------------------------
# Proxy API requests to Express backend running on port 3000
RewriteRule ^api/users/(.*)$ http://localhost:3000/users/$1 [P,L]
RewriteRule ^api/products/(.*)$ http://localhost:3000/products/$1 [P,L]

# Alternative: Redirect API requests to backend (if not using proxy)
# RewriteCond %{REQUEST_URI} ^/api/
# RewriteRule ^api/(.*)$ http://localhost:3000/$1 [R=301,L]

# ----------------------------------------------------------------------
# Frontend: Serve React build files (SPA fallback)
# ----------------------------------------------------------------------
# If the request is for a file that exists, serve it
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]

# If the request is for a directory that exists, serve it
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# All other requests: Serve index.html (React Router SPA)
RewriteRule ^ /client/dist/index.html [L]

# ----------------------------------------------------------------------
# Security Headers
# ----------------------------------------------------------------------
<IfModule mod_headers.c>
    # Protect sensitive files
    <FilesMatch "^\.">
        Order allow,deny
        Deny from all
    </FilesMatch>
    
    # Disable directory browsing
    Options -Indexes
    
    # Set default charset
    AddDefaultCharset UTF-8
</IfModule>

# ----------------------------------------------------------------------
# PHP Settings (if needed)
# ----------------------------------------------------------------------
<IfModule mod_php7.c>
    php_flag display_errors Off
    php_flag log_errors On
    php_value upload_max_filesize 10M
    php_value post_max_size 10M
</IfModule>

# ----------------------------------------------------------------------
# Browser Caching
# ----------------------------------------------------------------------
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpg "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/gif "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/pdf "access plus 1 month"
    ExpiresByType text/javascript "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType application/x-shockwave-flash "access plus 1 month"
    ExpiresByType image/x-icon "access plus 1 year"
    ExpiresDefault "access plus 2 days"
</IfModule>

